{
  "$schema": "https://raw.githubusercontent.com/rpdelaney/dotfiles/refs/heads/main/home/.config/io.datasette.llm/templates/brief.jsonschema.json",
  "type": "array",
  "items": {
    "type": "object",
    "properties": {
      "citation": { "type": "string" },
      "parties": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "name": { "type": "string" },
            "role": { "type": "array", "items": { "type": "string" } }
          },
          "required": [ "name", "role" ]
        }
      },
      "narrative": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "type": { "type": "string", "enum": ["fact"] },
            "data": { "type": "string" }
          },
          "required": [ "type", "data" ]
        }
      },
      "prior_proceedings": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "type": { "type": "string", "enum": ["prior_proceeding"] },
            "data": { "type": "string" }
          },
          "required": [ "type", "data" ]
        }
      },
      "holdings": {
        "type": "object",
        "properties": {
          "issue": { "type": "string" },
          "rule": { "type": "string" }
        },
        "required": [ "issue", "rule" ]
      },
      "application": { "type": "string" },
      "conclusion": { "type": "string" }
    },
    "required": [
      "citation",
      "parties",
      "narrative",
      "prior_proceedings",
      "holdings",
      "application",
      "conclusion"
    ]
  }
}
