{
    "__comments": [
      {
        "Configuration reference": "https://github.com/mikf/gallery-dl/blob/master/docs/configuration.rst",
        "Fix filename length errors with slices": "https://github.com/mikf/gallery-dl/issues/2771#issuecomment-1601564411"
      }
    ],
    "cookies": ["firefox"],
    "extractor": {
        "base-directory": "~/img/gallery-dl/",
        "TODO_directory": [
          "this doesn't work right yet",
          "fix it later",
          "-- OH YEAH? WHAT WAS THE PROBLEM, IDIOT?? WRITE IT DOWN ARGHHHH",
          "{username|author|user|datetime.now().strftime('%Y%m%d.%s')}",
          "{category}"
        ],
        "extension-map": {
            "jpeg": "jpg",
            "jpe" : "jpg",
            "jfif": "jpg",
            "jif" : "jpg",
            "jfi" : "jpg"
        },
        "postprocessors": [
            {
                "name": "metadata",
                "mode": "json"
            }
        ],
        "include": "all",

        "ytdl": {
            "enabled": true,
            "module": "yt_dlp"
        },
        "4chan": {
          "directory": {
            "": [
              "4chan",
              "{title}"
            ]
          },
          "filename": "{filename}.{extension}",
          "sleep": [1, 10]
        },
        "rule34us": {
          "filename": "{filename}_{timestamp}.{extension}"
        },
        "instagram": {
            "#": "try to evade bot detection",
            "directory": {
                "subcategory == 'tagged'": ["{tagged_username}", "tagged"],
                "": [
                    "{username}",
                    "{category}",
                    "{subcategory}"
                ]
            },
            "filename": "{media_id}_{shortcode}.{extension}",
            "videos": true,
            "sleep-request": "6-24",
            "sleep": "1-20",
            "max-retries": 3,
            "retry-sleep": [30, 60]
        },
        "reddit": {
            "directory": ["{author}"],
            "filename": "{id}_{num}.{extension}",
            "max-retries": 3,
            "refresh-token": "158243922968846-4kcqttZSjaakre02SbqNqkSLurLS_Q",
            "parent-directory": true,
            "parent-metadata": "_reddit",
            "retry-sleep": [30, 60],
            "sleep": "1-20",
            "sleep-request": "6-24",
            "videos": "true"
        },
        "tumblr": {
            "avatar": true
        },
        "imgur": {
            "mp4": "always",
            "directory":
            {
                "'_reddit' in locals()": []
            },
            "filename":
            {
                "'_reddit' in locals()": "{_reddit[id]} {id}.{extension}",
                ""                     : "{id}.{extension}"
            }
        },
        "redgifs": {
            "format": ["hd", "gif"]
        },
        "gfycat": {
            "format": ["webm", "mp4", "mobile", "gif"]
        }
    }
}
